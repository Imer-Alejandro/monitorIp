{
  "name": "ip-monitor",
  "version": "1.0.0",
  "description": "Monitor de IPs con alertas por correo y dashboard web",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "dev": "node index.js",
    "build": "pkg . --targets node18-win-x64 --output dist/MonitorIP.exe"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "public/**/*",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "nodemailer": "^6.9.8",
    "nodemon": "^3.1.14",
    "ping": "^0.4.4",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}